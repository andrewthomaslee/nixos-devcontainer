{
    "name": "NixOS DinD",
    "image": "andrewthomaslee/nixos-devcontainer:latest",
    "remoteUser": "code",
    "overrideCommand": false,
    "runArgs": [
        "--privileged",
        "--cap-add=SYS_ADMIN",
        "--security-opt=seccomp=unconfined",
        "--tmpfs",
        "/run",
        "--tmpfs",
        "/run/lock",
        "--tmpfs",
        "/tmp",
        "-v",
        "/sys/fs/cgroup:/sys/fs/cgroup:rw",
        "-v",
        "nixos-devcontainer-docker-data:/var/lib/docker",
        "-v",
        "nixos-devcontainer-store-data:/nix"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "jnoortheen.nix-ide",
                "meta.pyrefly",
                "ms-python.python",
                "charliermarsh.ruff",
                "Tailscale.vscode-tailscale"
            ]
        }
    }
}